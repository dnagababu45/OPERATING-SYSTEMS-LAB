#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>

int main() {
    int fd;
    char data[] = "Hello, File System Calls!";
    char buffer[100];

    // Create/Open file
    fd = open("sample.txt", O_CREAT | O_WRONLY | O_TRUNC, 0644);

    if (fd < 0) {
        printf("Error opening file.\n");
        return 1;
    }

    // Write to file
    write(fd, data, sizeof(data));

    // Close file
    close(fd);

    // Open file for reading
    fd = open("sample.txt", O_RDONLY);

    if (fd < 0) {
        printf("Error opening file for reading.\n");
        return 1;
    }

    // Read from file
    int bytes = read(fd, buffer, sizeof(buffer) - 1);
    buffer[bytes] = '\0';

    printf("Data read from file:\n%s\n", buffer);

    // Close file
    close(fd);

    return 0;
}
